# Telegram Bot — get from https://t.me/BotFather
# Create a bot with /newbot, then copy the token
TELEGRAM_BOT_TOKEN=your-bot-token-here
# The chat ID of the print shop owner's Telegram account
# Send a message to your bot, then visit:
# https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat_id
TELEGRAM_OWNER_CHAT_ID=your-chat-id-here

# Stripe — get from https://dashboard.stripe.com/apikeys (optional, for payments)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=PrintFlow

# Admin — Supabase user ID of the shop owner account
# After creating the admin account, copy the UUID from Supabase Auth dashboard
